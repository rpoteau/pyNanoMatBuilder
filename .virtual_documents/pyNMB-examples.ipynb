from pyNanoMatBuilder import platonicNPs as pNP
import importlib
importlib.reload(pNP)
importlib.reload(pyNMBu)

fcc = pNP.cube('fcc','Au',2.7,3,noOutput=True)
write("coords/fcccube.xyz", fcc.NP)
write("coords/fcccube_CoreSurface.xyz", fcc.NPcs)
with open(f"coords/fccCube.script", 'w') as f: f.write(fcc.jMolCS)

coords = fcc.NP.get_positions()
for i,p in enumerate(fcc.trPlanes):
    mol = fcc.NP.copy()
    rotCoords = pyNMBu.rotateMoltoAlignItWithAxis(coords,p[0:3],[0,0,1])
    mol.set_positions(rotCoords)
    if i == 0: 
        wa = 'w'
    else:
        wa = 'a'
    pyNMBu.writexyz('coords/fcccube_AlignedWithFacets.xyz',mol,wa)






